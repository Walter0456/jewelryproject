{
  "name": "jewel-admin-pro",
  "version": "1.0.0",
  "description": "Jewelry Store Admin Dashboard with PostgreSQL Backend",
  "type": "module",
  "scripts": {
    "start": "vite",
    "backend": "node backend/server.js",
    "start:dev": "node --watch backend/server.js",
    "build": "vite build",
    "preview": "vite preview",
    "db:init": "node -e \"import './scripts/init-db.js'\"",
    "snapshot:inventory": "node scripts/snapshot-inventory.js",
    "backup:run": "node scripts/backup-db.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "archiver": "^6.0.2",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.2",
    "jsqr": "1.4.0",
    "lucide-react": "^0.563.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.18.0",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode.react": "^1.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
